# ========= Server =========
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:8080

# ========= Database =========
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/vasista_pickles?retryWrites=true&w=majority

# ========= Auth =========
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# ========= Admin Seed =========
ADMIN_EMAIL=admin@vasistapickles.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Vasista Admin

# ========= Cloudinary (optional, for product/profile images) =========
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
